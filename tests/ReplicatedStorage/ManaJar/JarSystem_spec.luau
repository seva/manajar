local JarSystem = require(script.Parent.Parent.Parent.src.ReplicatedStorage.ManaJar)

return function()
	describe("JarSystem.CreateJar", function()
		it("should create a jar with zero mana and given maxMana", function()
			local jar = JarSystem.CreateJar(100)
			expect(jar.mana).toEqual(0)
			expect(jar.maxMana).toEqual(100)
			expect(jar.targetId).toEqual(nil)
		end)

		it("should reject non-positive maxMana", function()
			expect(function()
				JarSystem.CreateJar(0)
			end).toThrow()
			expect(function()
				JarSystem.CreateJar(-10)
			end).toThrow()
		end)
	end)

	describe("JarSystem.FillJar", function()
		it("should add mana to the jar", function()
			local jar = JarSystem.CreateJar(100)
			local ok, amount = JarSystem.FillJar(jar, 50)
			expect(ok).toEqual(true)
			expect(amount).toEqual(50)
			expect(jar.mana).toEqual(50)
		end)

		it("should not exceed maxMana", function()
			local jar = JarSystem.CreateJar(100)
			JarSystem.FillJar(jar, 120)
			expect(jar.mana).toEqual(100)
		end)

		it("should reject non-positive amounts", function()
			local jar = JarSystem.CreateJar(100)
			local ok, amount = JarSystem.FillJar(jar, 0)
			expect(ok).toEqual(false)
			expect(amount).toEqual(0)
			local ok2, _ = JarSystem.FillJar(jar, -5)
			expect(ok2).toEqual(false)
		end)
	end)

	describe("JarSystem.LinkTarget", function()
		it("should link a jar to a target when jar has mana", function()
			local jar = JarSystem.CreateJar(100)
			JarSystem.FillJar(jar, 50)
			local ok = JarSystem.LinkTarget(jar, "Player_123")
			expect(ok).toEqual(true)
			expect(jar.targetId).toEqual("Player_123")
		end)

		it("should fail to link when jar is empty", function()
			local jar = JarSystem.CreateJar(100)
			local ok = JarSystem.LinkTarget(jar, "Player_123")
			expect(ok).toEqual(false)
			expect(jar.targetId).toEqual(nil)
		end)
	end)

	describe("JarSystem.ClearTarget", function()
		it("should clear the linked target", function()
			local jar = JarSystem.CreateJar(100)
			JarSystem.FillJar(jar, 50)
			JarSystem.LinkTarget(jar, "Player_123")
			JarSystem.ClearTarget(jar)
			expect(jar.targetId).toEqual(nil)
		end)
	end)

	describe("JarSystem.GetFillRatio", function()
		it("should return 0 for empty jar", function()
			local jar = JarSystem.CreateJar(100)
			expect(JarSystem.GetFillRatio(jar)).toEqual(0)
		end)

		it("should return 0.5 for half-filled jar", function()
			local jar = JarSystem.CreateJar(100)
			JarSystem.FillJar(jar, 50)
			expect(JarSystem.GetFillRatio(jar)).toEqual(0.5)
		end)

		it("should return 1 for full jar", function()
			local jar = JarSystem.CreateJar(100)
			JarSystem.FillJar(jar, 100)
			expect(JarSystem.GetFillRatio(jar)).toEqual(1)
		end)
	end)

	describe("JarSystem.DrainJar", function()
		it("should drain all mana and return it", function()
			local jar = JarSystem.CreateJar(100)
			JarSystem.FillJar(jar, 75)
			local drained = JarSystem.DrainJar(jar)
			expect(drained).toEqual(75)
			expect(jar.mana).toEqual(0)
		end)
	end)
end
